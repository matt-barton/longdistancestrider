@{
    Layout = "_Layout";
}

@model LDS.Web.Admin.ViewModels.RunnerViewModel;

<div class="govuk-grid-row">
    <div class="govuk-grid-column-one-half">
        <table class="govuk-table">
            <thead class="govuk-table__head">
            <tr class="govuk-table__row">
                <th scope="row" class="govuk-table__header lds-table-cell">@Model.DisplayName</th>
                <td class="govuk-table__cell lds-table-cell">(@(String.IsNullOrEmpty(Model.Gender) ? "Gender not set" : Model.Gender))</td>
                <td class="govuk-table__cell lds-table-cell">
                    <a class="govuk-link govuk-link--no-visited-state" href="/Runner/Edit/@Model.Id">
                        Edit
                    </a>
                </td>
            </tr>
            </thead>
        </table>
    </div>
</div>

@if (Model.Aliases.Any())
{
    <div class="govuk-grid-row govuk-!-margin-bottom-4">
        <div class="govuk-grid-column-full">
            <span class="govuk-heading-s">Alias: </span>
            <span class="govuk-body">
                @(String.Join(", ", Model.Aliases))
            </span>
        </div>
    </div>
}

<div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
        @await Html.PartialAsync("_RunnerRaceParticipation", Model.RaceEntries)
    </div>
</div>

<div class="govuk-grid-row">
    <div class="govuk-grid-column-one-third">
        <table class="govuk-table">
            <tbody class="govuk-table__body">
            <tr class="govuk-table__row">
                <th scope="row" class="govuk-table__header lds-table-cell">Total:</th>
                <td class="govuk-table__cell lds-table-cell">@Model.TotalMiles?.ToString("0.###")</td>
            </tr>
            </tbody>
        </table>
    </div>
</div>