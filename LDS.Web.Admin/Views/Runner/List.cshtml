@{
    Layout = "_Layout";
}

@model List<LDS.Web.Admin.ViewModels.RunnerViewModel>

<div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
        <h1 class="govuk-heading-l">
            Runners
        </h1>
    </div>
</div>

<div class="govuk-grid-row">
    <div class="govuk-grid-column-one-third">
        <h2 class="govuk-heading-s">
            Name
        </h2>
    </div>
    <div class="govuk-grid-column-one-third">
        <h2 class="govuk-heading-s">
            Gender
        </h2>
    </div>
</div>

@foreach(var runner in Model)
{
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-third">
            <p class="govuk-body">
                @runner.DisplayName
            </p>
        </div>
        <div class="govuk-grid-column-one-third">
            <p class="govuk-body">
                @runner.Gender
            </p>
        </div>
        <div class="govuk-grid-column-one-third">
            <a class="govuk-link govuk-link--no-visited-state" href="/Runner/@runner.Id">
                View                
            </a>
            <a class="govuk-link govuk-link--no-visited-state" href="/Runner/Edit/@runner.Id">
                Edit                
            </a>
        </div>
    </div>
}

