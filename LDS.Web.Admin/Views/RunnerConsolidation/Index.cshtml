@{
    Layout = "_Layout";
}

@model LDS.Web.Admin.ViewModels.RunnerConsolidationViewModel;

<div class="govuk-grid-row">
    <div class="govuk-grid-column-full">
        <h1 class="govuk-heading-l">
            Runner Consolidation
        </h1>
    </div>
</div>

<form method="post" enctype="application/x-www-form-urlencoded">
    @Html.AntiForgeryToken()

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-half">
            <h2 class="govuk-heading-m">
                Runner to keep
            </h2>
            @Html.DropDownListFor(m => m.RunnerToKeepId, new SelectList(Model.RunnerToKeep, "Id", "FullName"), new { @class = "govuk-select" })
        
        </div>
        <div class="govuk-grid-column-one-half">
            <h2 class="govuk-heading-m">
                Runner to remove
            </h2>
            @Html.DropDownListFor(m => m.RunnerToRemoveId, new SelectList(Model.RunnerToRemove, "Id", "FullName"), new { @class = "govuk-select" })
        </div>
    </div>

    <p id="passport-issued-error" class="govuk-error-message">
        <span class="govuk-visually-hidden">Error:</span> @Html.ValidationMessageFor(m => m.RunnerToRemove)
    </p>

    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            @Html.CheckBoxFor(m => m.CreateAlias)
            <span class="govuk-body">Create Alias?</span>
        </div>
    </div>
    <p/>
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-full">
            <button type="submit" class="govuk-button" data-module="govuk-button">
                Consolidate
            </button>
        </div>
    </div>
</form>

@if(Model.RemovedRunnerId.HasValue)
{
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-third">
            <p class="govuk-heading-s">
                Removed runner
            </p>
        </div>
        <div class="govuk-grid-column-two-thirds">
            <p class="govuk-body">
                @Model.RemovedRunnerName (@Model.RemovedRunnerId)
            </p>
        </div>
    </div>
    <div class="govuk-grid-row">
        <div class="govuk-grid-column-one-third">
            <p class="govuk-heading-s">
                Moved race entries
            </p>
        </div>
        <div class="govuk-grid-column-two-thirds">
                @await Html.PartialAsync("_RunnerRaceParticipation", Model.EntriesMoved) 
        </div>
    </div>
    @if(Model.AliasCreated)
    {
        <div class="govuk-grid-row">
            <div class="govuk-grid-column-one-third">
                <p class="govuk-heading-s">
                    Alias Created
                </p>
            </div>
            <div class="govuk-grid-column-two-thirds">
                <p class="govuk-body">
                    <a class="govuk-link govuk-link--no-visited-state" href="/Runner/@Model.KeptRunnerId">@Model.KeptRunnerName</a> (@Model.KeptRunnerId) - AKA "@Model.RemovedRunnerName" 
                </p>
            </div>
        </div>
    }
}